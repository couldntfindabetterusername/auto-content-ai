{
  "name": "autocontent-api",
  "version": "0.1.0",
  "private": true,
  "description": "AutoContent backend API",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "nest start --watch",
    "start": "nest start",
    "build": "nest build",
    "start:api": "node dist/main",
    "start:worker:prod": "node dist/workers/worker.js",
    "start:api-with-worker": "bash scripts/start-combined.sh",
    "start:worker": "tsx src/workers/worker.ts",
    "start:worker:dev": "tsx watch src/workers/worker.ts",
		"start:debug": "nest start --debug --watch",
		"start:worker:debug": "node --inspect=9230 --require tsx/cjs src/workers/worker.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^10.2.10",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.10",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.2.10",
    "@nestjs/throttler": "^5.2.0",
    "bullmq": "^5.79.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "connect-redis": "^9.0.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "express-session": "^1.19.0",
    "google-trends-api": "^4.9.2",
    "googleapis": "^173.0.0",
    "ioredis": "^5.11.1",
    "marked": "^18.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "playwright": "^1.61.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3"
  }
