# ============================================================
# LOCAL DOCKER COMPOSE DEVELOPMENT
# Copy to .env and fill in values for local dev
# ============================================================

# Database — local Docker Compose
DATABASE_URL=postgresql://autocontent:autocontent@localhost:5432/autocontent

# Postgres service credentials (used by docker-compose.yml service names)
POSTGRES_DB=autocontent
POSTGRES_USER=autocontent
POSTGRES_PASSWORD=autocontent

# Redis — local Docker Compose
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend origin for local dev
FRONTEND_URL=http://localhost:5173

# ============================================================
# FREE / HOSTED DEPLOYMENT
# For Render/Koyeb backend + Vercel/Netlify frontend
# Replace the local values above with these when deploying
# ============================================================

# External Postgres (Neon, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# External Redis with TLS (Upstash, etc.)
# REDIS_URL=rediss://default:password@host:6379

# Public URL of deployed frontend
# FRONTEND_URL=https://your-app.vercel.app

# Public URL of deployed backend — set this in the frontend host's env vars
# VITE_API_URL=https://your-backend.onrender.com

# ============================================================
# EXTERNAL APIs (required in all environments)
# ============================================================

YOUTUBE_API_KEY=your_youtube_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
LLM_TIMEOUT_MS=60000

# ============================================================
# AUTHENTICATION
# ============================================================

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Local dev callback:
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Hosted callback (set to backend public URL):
# GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback
SESSION_SECRET=your_session_secret_here

# ============================================================
# SERVER
# ============================================================

PORT=3000
NODE_ENV=development

# ============================================================
# ADMIN
# ============================================================

ADMIN_EMAILS=your_admin_email@example.com
