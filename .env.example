# Database (local dev)
DATABASE_URL=postgresql://user:password@localhost:5432/autocontent

# Postgres service credentials (Docker — used by docker-compose.yml)
POSTGRES_DB=autocontent
POSTGRES_USER=autocontent
POSTGRES_PASSWORD=autocontent

# Cache & Queue
REDIS_URL=redis://localhost:6379

# External APIs
YOUTUBE_API_KEY=your_youtube_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
LLM_TIMEOUT_MS=60000

# Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
SESSION_SECRET=your_session_secret_here
